        FROM order_comment o
        <include refid="extendQueryCommon"/>
        <include refid="query_condition"/>
        <if test="query.orderBy!=null">
            order by ${query.orderBy}
        </if>
        <if test="query.simplePage!=null">
            limit #{query.simplePage.start},#{query.simplePage.end}
        </if>
    </select>

    <sql id="extendQueryCommon">
        <if test="query.queryUserInfo">
            left join user_info u on o.user_id=u.user_id
        </if>
        <if test="query.queryProduct">
            left join product_info p on o.product_id=p.product_id
        </if>
    </sql>

