            </if>
            <if test="query.recommentTimeEnd!= null and query.recommentTimeEnd!=''">
                <![CDATA[ and  o.recomment_time< date_sub(str_to_date(#{query.recommentTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
            </if>
            <if test="query.recommentImagesFuzzy!= null  and query.recommentImagesFuzzy!=''">
                and o.recomment_images like concat('%', #{query.recommentImagesFuzzy}, '%')
            </if>
            <if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
                and o.user_id like concat('%', #{query.userIdFuzzy}, '%')
            </if>
            <if test="query.propertyInfoFuzzy!= null  and query.propertyInfoFuzzy!=''">
                and o.property_info like concat('%', #{query.propertyInfoFuzzy}, '%')
            </if>
            <if test="query.nickNameFuzzy!= null  and query.nickNameFuzzy!=''">
                and u.nick_name like concat('%', #{query.nickNameFuzzy}, '%')
            </if>

            <if test="query.productNameFuzzy!= null  and query.productNameFuzzy!=''">
                and p.product_name like concat('%', #{query.productNameFuzzy}, '%')
            </if>
        </where>
    </sql>
    <!-- 查询集合-->
    <select id="selectList" resultMap="base_result_map">
        SELECT
        <include refid="base_column_list"/>
        <if test="query.queryUserInfo">
