    <!-- 通用查询结果列-->
    <sql id="base_column_list">
        o.order_id,o.product_id,o.comment_content,o.comment_time,o.comment_images,
        o.star,o.comment_biz_reply,o.recomment_content,o.recomment_time,o.recomment_images,
        o.user_id,o.property_info,o.status
    </sql>

    <sql id="base_condition_filed">
        <if test="query.orderId != null and query.orderId!=''">
            and o.order_id = #{query.orderId}
        </if>
        <if test="query.productId != null and query.productId!=''">
            and o.product_id = #{query.productId}
        </if>
        <if test="query.commentContent != null and query.commentContent!=''">
            and o.comment_content = #{query.commentContent}
        </if>
        <if test="query.commentTime != null and query.commentTime!=''">
            <![CDATA[ and  o.comment_time=str_to_date(#{query.commentTime}, '%Y-%m-%d') ]]>
        </if>
        <if test="query.commentImages != null and query.commentImages!=''">
            and o.comment_images = #{query.commentImages}
        </if>
        <if test="query.star != null">
            and o.star = #{query.star}
        </if>
        <if test="query.commentBizReply != null and query.commentBizReply!=''">
            and o.comment_biz_reply = #{query.commentBizReply}
        </if>
        <if test="query.recommentContent != null and query.recommentContent!=''">
            and o.recomment_content = #{query.recommentContent}
        </if>
        <if test="query.recommentTime != null and query.recommentTime!=''">
            <![CDATA[ and  o.recomment_time=str_to_date(#{query.recommentTime}, '%Y-%m-%d') ]]>
        </if>
        <if test="query.recommentImages != null and query.recommentImages!=''">
            and o.recomment_images = #{query.recommentImages}
        </if>
        <if test="query.userId != null and query.userId!=''">
            and o.user_id = #{query.userId}
        </if>
        <if test="query.propertyInfo != null and query.propertyInfo!=''">
            and o.property_info = #{query.propertyInfo}
        </if>
        <if test="query.status != null">
            and o.status = #{query.status}
        </if>

    </sql>

    <!-- 通用查询条件列-->
    <sql id="query_condition">
        <where>
            <include refid="base_condition_filed"/>
            <if test="query.orderIdFuzzy!= null  and query.orderIdFuzzy!=''">
                and o.order_id like concat('%', #{query.orderIdFuzzy}, '%')
            </if>
            <if test="query.productIdFuzzy!= null  and query.productIdFuzzy!=''">
                and o.product_id like concat('%', #{query.productIdFuzzy}, '%')
            </if>
            <if test="query.commentContentFuzzy!= null  and query.commentContentFuzzy!=''">
                and o.comment_content like concat('%', #{query.commentContentFuzzy}, '%')
            </if>
            <if test="query.commentTimeStart!= null and query.commentTimeStart!=''">
                <![CDATA[ and  o.comment_time>=str_to_date(#{query.commentTimeStart}, '%Y-%m-%d') ]]>
            </if>
            <if test="query.commentTimeEnd!= null and query.commentTimeEnd!=''">
                <![CDATA[ and  o.comment_time< date_sub(str_to_date(#{query.commentTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
            </if>
            <if test="query.commentImagesFuzzy!= null  and query.commentImagesFuzzy!=''">
                and o.comment_images like concat('%', #{query.commentImagesFuzzy}, '%')
            </if>
            <if test="query.commentBizReplyFuzzy!= null  and query.commentBizReplyFuzzy!=''">
                and o.comment_biz_reply like concat('%', #{query.commentBizReplyFuzzy}, '%')
            </if>
            <if test="query.recommentContentFuzzy!= null  and query.recommentContentFuzzy!=''">
                and o.recomment_content like concat('%', #{query.recommentContentFuzzy}, '%')
            </if>
            <if test="query.recommentTimeStart!= null and query.recommentTimeStart!=''">
