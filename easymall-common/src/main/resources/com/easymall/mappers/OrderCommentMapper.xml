        <result column="product_id" property="productId"/>
        <!--评价内容-->
        <result column="comment_content" property="commentContent"/>
        <!--评价时间-->
        <result column="comment_time" property="commentTime"/>
        <!--评价图片-->
        <result column="comment_images" property="commentImages"/>
        <!--评价星级-->
