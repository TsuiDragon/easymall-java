<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easymall.mappers.OrderInfoMapper">

    <!--实体映射-->
    <resultMap id="base_result_map" type="com.easymall.entity.po.OrderInfo">
        <!--订单ID-->
        <result column="order_id" property="orderId"/>
        <!--金额-->
        <result column="amount" property="amount"/>
        <!--用户ID-->
        <result column="user_id" property="userId"/>
        <!--订单创建时间-->
        <result column="order_time" property="orderTime"/>
        <!---1已删除 0:待付款 1:已付款,待发货  2:已发货  3:已完成 4:已取消 5:已关闭 6:已退款 7:部分退款-->
        <result column="order_status" property="orderStatus"/>
        <!--支付通道-->
        <result column="pay_channel" property="payChannel"/>
        <!--支付场景-->
        <result column="pay_scene" property="payScene"/>
        <!--支付订单号-->
        <result column="pay_order_id" property="payOrderId"/>
        <!--通道ID-->
        <result column="channel_order_Id" property="channelOrderId"/>
        <!--评价状态 0:未评价  1:已评价  2:已追评-->
        <result column="comment_status" property="commentStatus"/>

        <result column="nick_name" property="nickName"/>

        <result column="avatar" property="avatar"/>

        <collection property="orderItemList" ofType="com.easymall.entity.po.OrderItem">
            <!--订单明细ID-->
            <result column="order_item_id" property="orderItemId"/>
            <!--订单ID-->
            <result column="order_id" property="orderId"/>
            <!--封面-->
            <result column="cover" property="cover"/>
            <!--商品ID-->
            <result column="product_id" property="productId"/>
            <!--商品名称-->
            <result column="product_name" property="productName"/>
            <!--属性值id组hash-->
            <result column="property_value_id_hash" property="propertyValueIdHash"/>
            <!--属性信息-->
            <result column="property_info" property="propertyInfo"/>
            <!--价格-->
            <result column="item_amount" property="itemAmount"/>
            <!--数量-->
            <result column="buy_count" property="buyCount"/>
            <!--状态 0:已退款 1:正常-->
            <result column="order_item_status" property="orderItemStatus"/>
            <!--备注-->
            <result column="remark" property="remark"/>
        </collection>
    </resultMap>


    <!-- 通用查询结果列-->
    <sql id="base_column_list">
        o.order_id,o.amount,o.user_id,o.order_time,o.order_status,
        o.pay_channel,o.pay_scene,o.pay_order_id,o.channel_order_Id,o.comment_status

    </sql>

    <sql id="base_condition_filed">
        <if test="query.orderId != null and query.orderId!=''">
            and o.order_id = #{query.orderId}
        </if>
        <if test="query.amount != null">
            and o.amount = #{query.amount}
        </if>
        <if test="query.userId != null and query.userId!=''">
            and o.user_id = #{query.userId}
        </if>
        <if test="query.orderTime != null and query.orderTime!=''">
            <![CDATA[ and DATE_FORMAT(o.order_time ,'%Y-%m-%d') = #{query.orderTime} ]]>
        </if>
        <if test="query.orderStatus != null">
            and o.order_status = #{query.orderStatus}
        </if>
        <if test="query.payChannel != null and query.payChannel!=''">
            and o.pay_channel = #{query.payChannel}
        </if>
        <if test="query.payScene != null and query.payScene!=''">
            and o.pay_scene = #{query.payScene}
        </if>
        <if test="query.payOrderId != null and query.payOrderId!=''">
            and o.pay_order_id = #{query.payOrderId}
        </if>
        <if test="query.channelOrderId != null and query.channelOrderId!=''">
            and o.channel_order_Id = #{query.channelOrderId}
        </if>
        <if test="query.commentStatus != null">
            and o.comment_status = #{query.commentStatus}
        </if>
    </sql>

    <!-- 通用查询条件列-->
    <sql id="query_condition">
        <where>
            <include refid="base_condition_filed"/>
            <if test="query.orderIdFuzzy!= null  and query.orderIdFuzzy!=''">
                and o.order_id like concat('%', #{query.orderIdFuzzy}, '%')
            </if>
            <if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
                and o.user_id like concat('%', #{query.userIdFuzzy}, '%')
            </if>
            <if test="query.orderTimeStart!= null and query.orderTimeStart!=''">
                <![CDATA[ and  o.order_time>=str_to_date(#{query.orderTimeStart}, '%Y-%m-%d') ]]>
            </if>
            <if test="query.orderTimeEnd!= null and query.orderTimeEnd!=''">
                <![CDATA[ and  o.order_time< date_sub(str_to_date(#{query.orderTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
            </if>
            <if test="query.payChannelFuzzy!= null  and query.payChannelFuzzy!=''">
                and o.pay_channel like concat('%', #{query.payChannelFuzzy}, '%')
            </if>
            <if test="query.paySceneFuzzy!= null  and query.paySceneFuzzy!=''">
                and o.pay_scene like concat('%', #{query.paySceneFuzzy}, '%')
            </if>
            <if test="query.payOrderIdFuzzy!= null  and query.payOrderIdFuzzy!=''">
                and o.pay_order_id like concat('%', #{query.payOrderIdFuzzy}, '%')
            </if>
            <if test="query.channelOrderIdFuzzy!= null  and query.channelOrderIdFuzzy!=''">
                and o.channel_order_Id like concat('%', #{query.channelOrderIdFuzzy}, '%')
            </if>
            <if test="query.orderIdList!=null">
                and o.order_id in(<foreach collection="query.orderIdList" item="item" separator="," close="">#{item}</foreach>)
            </if>
            <if test="query.orderStatusList!=null">
                and o.order_status in(<foreach collection="query.orderStatusList" item="item" separator="," close="">#{item}</foreach>)
            </if>
            <if test="query.executeOrderStatusList!=null">
                and o.order_status not in(<foreach collection="query.executeOrderStatusList" item="item" separator="," close="">#{item}</foreach>)
            </if>
            <if test="query.productNameFuzzy!=null  and query.productNameFuzzy!=''">
                and i.product_name like concat('%', #{query.productNameFuzzy}, '%')
            </if>
        </where>
    </sql>

    <select id="selectList" resultMap="base_result_map">
        SELECT
        <include refid="base_column_list"/>
        <if test="query.queryItems">
            ,i.*
        </if>
        <if test="query.queryUser">
            ,u.nick_name ,u.avatar
        </if>
        FROM order_info o
        <if test="query.queryItems">
            left join order_item i on o.order_id=i.order_id
        </if>
        <if test="query.queryUser">
            left join user_info u on o.user_id=u.user_id
        </if>
        <include refid="query_condition"/>
        <if test="query.orderBy!=null">
            order by ${query.orderBy}
        </if>
        <if test="query.simplePage!=null">
            limit #{query.simplePage.start},#{query.simplePage.end}
        </if>
    </select>

    <!-- 查询数量-->
    <select id="selectCount" resultType="java.lang.Integer">
        SELECT count(1) FROM order_info o
        <if test="query.queryItems">
            left join order_item i on o.order_id=i.order_id
        </if>
        <include refid="query_condition"/>
    </select>

