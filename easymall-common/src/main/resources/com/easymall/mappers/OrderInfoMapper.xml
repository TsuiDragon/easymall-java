    <select id="selectOrderTotalAmount" resultType="java.math.BigDecimal">
        select ifnull(sum(amount),0) from order_info where DATE(order_time) = #{orderTime} and order_status in(
        <foreach collection="orderStatus" separator="," item="item">#{item}</foreach>
        )
    </select>

    <update id="updateOrderStatusBatch">
