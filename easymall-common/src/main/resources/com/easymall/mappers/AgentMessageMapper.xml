<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easymall.mappers.AgentMessageMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.easymall.entity.po.AgentMessage">
		<!--消息ID-->
		<id column="message_id" property="messageId"  />
		<!--AI消息-->
		<result column="assistant_message" property="assistantMessage"  />
		<!--用户消息-->
		<result column="user_message" property="userMessage"  />
		<!--发送时间-->
		<result column="send_time" property="sendTime"  />
		<!--用户ID-->
		<result column="user_id" property="userId"  />
		<!--0:用户取消 1:回答中 2:完成-->
		<result column="status" property="status"  />
		<!--业务类型-->
		<result column="biz_type" property="bizType"  />
		<!---->
		<result column="biz_data" property="bizData"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 a.message_id,a.assistant_message,a.user_message,a.send_time,a.user_id,
		 a.status,a.biz_type,a.biz_data
	</sql>

	<sql id="base_condition_filed">
			<if test="query.messageId != null">
				 and  a.message_id = #{query.messageId}
			</if>
			<if test="query.assistantMessage != null and query.assistantMessage!=''">
				 and  a.assistant_message = #{query.assistantMessage}
			</if>
			<if test="query.userMessage != null and query.userMessage!=''">
				 and  a.user_message = #{query.userMessage}
			</if>
			<if test="query.sendTime != null and query.sendTime!=''">
				 <![CDATA[ and  a.send_time=str_to_date(#{query.sendTime}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.userId != null and query.userId!=''">
				 and  a.user_id = #{query.userId}
			</if>
			<if test="query.status != null">
				 and  a.status = #{query.status}
			</if>
			<if test="query.bizType != null and query.bizType!=''">
				 and  a.biz_type = #{query.bizType}
			</if>
			<if test="query.bizData != null and query.bizData!=''">
				 and  a.biz_data = #{query.bizData}
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.assistantMessageFuzzy!= null  and query.assistantMessageFuzzy!=''">
				 and  a.assistant_message like concat('%', #{query.assistantMessageFuzzy}, '%')
			</if>
			<if test="query.userMessageFuzzy!= null  and query.userMessageFuzzy!=''">
				 and  a.user_message like concat('%', #{query.userMessageFuzzy}, '%')
			</if>
			<if test="query.sendTimeStart!= null and query.sendTimeStart!=''">
				 <![CDATA[ and  a.send_time>=str_to_date(#{query.sendTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.sendTimeEnd!= null and query.sendTimeEnd!=''">
				 <![CDATA[ and  a.send_time< date_sub(str_to_date(#{query.sendTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
			<if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
				 and  a.user_id like concat('%', #{query.userIdFuzzy}, '%')
			</if>
			<if test="query.bizTypeFuzzy!= null  and query.bizTypeFuzzy!=''">
				 and  a.biz_type like concat('%', #{query.bizTypeFuzzy}, '%')
			</if>
			<if test="query.bizDataFuzzy!= null  and query.bizDataFuzzy!=''">
				 and  a.biz_data like concat('%', #{query.bizDataFuzzy}, '%')
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM agent_message a <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM agent_message a <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="com.easymall.entity.po.AgentMessage">
		<selectKey keyProperty="bean.messageId" resultType="Integer" order="AFTER">
