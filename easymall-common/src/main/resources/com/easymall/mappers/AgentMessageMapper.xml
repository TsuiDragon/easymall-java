			</if>
			<if test="bean.status != null">
				 status,
			</if>
			<if test="bean.bizType != null">
				 biz_type,
			</if>
			<if test="bean.bizData != null">
				 biz_data,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.assistantMessage!=null">
				 #{bean.assistantMessage},
			</if>
			<if test="bean.userMessage!=null">
				 #{bean.userMessage},
			</if>
			<if test="bean.sendTime!=null">
