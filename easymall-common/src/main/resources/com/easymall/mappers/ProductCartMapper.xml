<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easymall.mappers.ProductCartMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.easymall.entity.po.ProductCart">
		<!--购物车ID-->
		<result column="cart_id" property="cartId"/>
		<!--用户ID-->
		<result column="user_id" property="userId"/>
		<!--商品ID-->
		<result column="product_id" property="productId"/>
		<!--属性值id组-->
		<result column="property_value_ids" property="propertyValueIds"/>
		<!--属性值id组hash-->
		<result column="property_value_id_hash" property="propertyValueIdHash"/>
		<!--数量-->
		<result column="buy_count" property="buyCount"/>
		<!--更新时间-->
		<result column="last_update_time" property="lastUpdateTime"/>
		<!--创建时间-->
		<result column="create_time" property="createTime"/>
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		p.cart_id,p.user_id,p.product_id,p.property_value_ids,p.property_value_id_hash,
        p.buy_count,p.last_update_time,p.create_time
	</sql>

	<sql id="base_condition_filed">
		<if test="query.cartId != null and query.cartId!=''">
			and p.cart_id = #{query.cartId}
		</if>
		<if test="query.userId != null and query.userId!=''">
			and p.user_id = #{query.userId}
		</if>
		<if test="query.productId != null and query.productId!=''">
			and p.product_id = #{query.productId}
		</if>
		<if test="query.propertyValueIds != null and query.propertyValueIds!=''">
			and p.property_value_ids = #{query.propertyValueIds}
		</if>
		<if test="query.propertyValueIdHash != null and query.propertyValueIdHash!=''">
			and p.property_value_id_hash = #{query.propertyValueIdHash}
		</if>
		<if test="query.buyCount != null">
			and p.buy_count = #{query.buyCount}
		</if>
		<if test="query.lastUpdateTime != null and query.lastUpdateTime!=''">
			<![CDATA[ and  p.last_update_time=str_to_date(#{query.lastUpdateTime}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.createTime != null and query.createTime!=''">
			<![CDATA[ and  p.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
		</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
		<where>
			<include refid="base_condition_filed"/>
			<if test="query.cartIdFuzzy!= null  and query.cartIdFuzzy!=''">
				and p.cart_id like concat('%', #{query.cartIdFuzzy}, '%')
			</if>
			<if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
				and p.user_id like concat('%', #{query.userIdFuzzy}, '%')
			</if>
			<if test="query.productIdFuzzy!= null  and query.productIdFuzzy!=''">
				and p.product_id like concat('%', #{query.productIdFuzzy}, '%')
			</if>
			<if test="query.propertyValueIdsFuzzy!= null  and query.propertyValueIdsFuzzy!=''">
				and p.property_value_ids like concat('%', #{query.propertyValueIdsFuzzy}, '%')
			</if>
			<if test="query.propertyValueIdHashFuzzy!= null  and query.propertyValueIdHashFuzzy!=''">
				and p.property_value_id_hash like concat('%', #{query.propertyValueIdHashFuzzy}, '%')
			</if>
			<if test="query.lastUpdateTimeStart!= null and query.lastUpdateTimeStart!=''">
				<![CDATA[ and  p.last_update_time>=str_to_date(#{query.lastUpdateTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.lastUpdateTimeEnd!= null and query.lastUpdateTimeEnd!=''">
				<![CDATA[ and  p.last_update_time< date_sub(str_to_date(#{query.lastUpdateTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				<![CDATA[ and  p.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				<![CDATA[ and  p.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
		</where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map">
		SELECT
		<include refid="base_column_list"/>
		FROM product_cart p
		<include refid="query_condition"/>
		<if test="query.orderBy!=null">
			order by ${query.orderBy}
		</if>
		<if test="query.simplePage!=null">
			limit #{query.simplePage.start},#{query.simplePage.end}
		</if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer">
		SELECT count(1) FROM product_cart p
		<include refid="query_condition"/>
	</select>

